{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron", "schedule": "0 8 * * 1" }
  ],
  "functions": {
    "api/analyze.js": { "maxDuration": 300, "memory": 1024 },
    "api/cron.js": { "maxDuration": 300, "memory": 1024 },
    "api/sheet.js": { "maxDuration": 30 },
    "api/data.js": { "maxDuration": 30 },
    "api/reports.js": { "maxDuration": 30 }
  }
}
